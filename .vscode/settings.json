{
  "php.autoloading": {
    "mode": "composer"
  },
  "php.validate.executablePath": "php",
  "php.format.enable": true,
  "intelephense.environment.documentRoot": "${workspaceFolder}/public",
  "intelephense.stubs": [
    "bcmath",
    "bz2",
    "Core",
    "curl",
    "date",
    "dba",
    "dom",
    "enchant",
    "fileinfo",
    "filter",
    "ftp",
    "gd",
    "gearman",
    "gettext",
    "gmp",
    "hash",
    "iconv",
    "imap",
    "intl",
    "json",
    "ldap",
    "libsodium",
    "libxml",
    "mbstring",
    "memcache",
    "memcached",
    "mongo",
    "mongodb",
    "mssql",
    "mysql",
    "mysqli",
    "oci8",
    "odbc",
    "openssl",
    "pcntl",
    "pcre",
    "PDO",
    "pgsql",
    "Phar",
    "posix",
    "readline",
    "Reflection",
    "regex",
    "session",
    "SimpleXML",
    "socket",
    "sockets",
    "sodium",
    "SPL",
    "sqlite3",
    "ssh2",
    "standard",
    "superglobals",
    "sysvmsg",
    "sysvsem",
    "sysvshm",
    "tidy",
    "tokenizer",
    "xml",
    "xmlreader",
    "xmlrpc",
    "xmlwriter",
    "yaml",
    "zip",
    "zlib"
  ],
  "intelephense.files.exclude": [
    "**/.git",
    "**/.pytest_cache",
    "**node_modules",
    "**/vendor"
  ],
  "intelephense.maxMemory": 4096,
  "[php]": {
    "editor.defaultFormatter": "chuaple.php-formatter",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "never"
    }
  }
}